nat_mul_comm : (a : Nat) -> (b : Nat) -> (a * b) == (b * a);

nat_mul_comm = nat_ind (\a. (b : Nat) -> (a * b) == (b * a))
    (\b .
        h1 : 0 == (0 * b);
        h1 = nat_mul_zero_inv b;

        h2 : 0 == (b * 0);
        h2 = nat_mul_zero_rev_inv b;

        h1 (\x. x == (b * 0)),
        h2 (\x. 0 == x),
        rfl Nat 0
    )
    (\a h b.
        h1 : (a * b) == (b * a);
        h1 = h b;

        h2 : ((a * b) + b) == ((S a) * b);
        h2 = eq_symm Nat ((S a) * b) ((a * b) + b), nat_mul_succ a b;

        h3 : ((b * a) + b) == (b * (S a));
        h3 = eq_symm Nat (b * (S a)) ((b * a) + b), nat_mul_succ_rev b a;

        h4 : ((a * b) + b) == ((b * a) + b);
        h4 = h1 (\x. ((a * b) + b) == (x + b)), rfl Nat ((a * b) + b);

        h5 : ((S a) * b) == ((b * a) + b);
        h5 = eq_symm Nat ((b * a) + b) ((S a) * b),
            h2 (\x. ((b * a) + b) == x),
            eq_symm Nat ((a * b) + b) ((b * a) + b)
            h4;
            
        h6 : ((S a) * b) == (b * (S a));
        h6 = h3 (\x. ((S a) * b) == x) h5;

        h6
    );

nat_mul_distrib_right : (a : Nat) -> (b : Nat) -> (c : Nat) -> ((a + b) * c) == ((a * c) + (b * c));

nat_mul_distrib_right = \a b c.
    h1 : (c * (a + b)) == ((c * a) + (c * b));
    h1 = nat_mul_distrib_left c a b;

    h2 : (c * (a + b)) == ((a + b) * c);
    h2 = nat_mul_comm c (a + b);

    h3 : (c * a) == (a * c);
    h3 = nat_mul_comm c a;

    h4 : (c * b) == (b * c);
    h4 = nat_mul_comm c b;

    h5 : ((c * a) + (c * b)) == ((a * c) + (b * c));
    h5 = 
        h4 (\x. ((c * a) + (c * b)) == ((a * c) + x)),
        h3 (\x. ((c * a) + (c * b)) == (x + (c * b))),
        rfl Nat ((c * a) + (c * b));

    h6 : ((a + b) * c) == ((c * a) + (c * b));
    h6 = h1 (\x. ((a + b) * c) == x),
        eq_symm Nat (c * (a + b)) ((a + b) * c) h2;

    h7 : ((a + b) * c) == ((a * c) + (b * c));
