
Eq =
    \A: Type. 
    \x: A. 
    \y: A. 
    (P: A -> Type) -> P x -> P y;

Eq.refl = 
    \A: Type. 
    \x: A.
    \P: A -> Type. 
    \h: P x.
    h;

Eq.symm = 
    \A: Type. 
    \x: A. 
    \y: A.
    \h: Eq A x y.
    h (\y: A. Eq A y x) (Eq.refl A x);

Eq.trans = 
    \A: Type. 
    \x: A. 
    \y: A. 
    \z: A. 
    \h1: Eq A x y.
    \h2: Eq A y z. 
    h2 (Eq A x) h1;

Eq.congr_arg = 
    \A: Type. 
    \B: Type. 
    \f: A -> B.
    \x: A. 
    \y: A.
    \h: Eq A x y.
    h (\y: A. Eq B (f x) (f y)) (Eq.refl B (f x));

Eq.congr_fn = 
    \A: Type. 
    \B: Type.
    \f: A -> B. 
    \g: A -> B. 
    \x: A. 
    \h: Eq (A -> B) f g. h (\g: A -> B. Eq B (f x) (g x)) (Eq.refl B (f x));

False = (R: Type) -> R;

Not = \A: Type. A -> False;

Set = \A: Type. A -> Type;

#axiom Nat: Type;

#axiom Nat.zero: Nat;

#axiom Nat.succ: Nat -> Nat;

#axiom Nat.ind: 
    (P: Set Nat) ->
    P Nat.zero -> 
    ((x: Nat) -> P x -> P (Nat.succ x)) -> 
    (n: Nat) ->
    P n;

#axiom Nat.ind.zero: 
    (P: Set Nat) ->
    (z: P Nat.zero) -> 
    (s: (x: Nat) -> P x -> P (Nat.succ x)) -> 
    Eq (P Nat.zero) (Nat.ind P z s Nat.zero) z;

#axiom Nat.ind.succ: 
    (P: Set Nat) ->
    (z: P Nat.zero) -> 
    (s: (x: Nat) -> P x -> P (Nat.succ x)) -> 
    (n: Nat) ->
    Eq (P (Nat.succ n)) (Nat.ind P z s (Nat.succ n)) (s n (Nat.ind P z s n));

Nat.add = \n: Nat. Nat.ind (\m: Nat. Nat) n (\m: Nat. Nat.succ);

Nat.add_zero = \n: Nat. Nat.ind.zero (\m: Nat. Nat) n (\m: Nat. Nat.succ);

#check Nat.add_zero: (n: Nat) -> Eq Nat (Nat.add n Nat.zero) n;

Nat.add_succ = \n: Nat. Nat.ind.succ (\m: Nat. Nat) n (\m: Nat. Nat.succ); 

#check Nat.add_succ: (n: Nat) -> (m: Nat) -> Eq Nat (Nat.add n (Nat.succ m)) (Nat.succ (Nat.add n m)); 

Nat.zero_add = Nat.ind 
    (\n: Nat. Eq Nat (Nat.add Nat.zero n) n) 
    (Nat.add_zero Nat.zero) 
    (\n: Nat. \h: Eq Nat (Nat.add Nat.zero n) n. 
        h (\x: Nat. Eq Nat (Nat.add Nat.zero (Nat.succ n)) (Nat.succ x)) (Nat.add_succ Nat.zero n));

